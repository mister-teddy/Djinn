# Copy to .env and fill in. `make up` reads this and seeds Djinn's settings.
# .env is gitignored — never commit your real key.

# openai | gemini
DJINN_PROVIDER=

# Your provider API key (sk-... for OpenAI). Required for wishes.
DJINN_API_KEY=

# A chat model must be chosen before wishing.
DJINN_CHAT_MODEL=
