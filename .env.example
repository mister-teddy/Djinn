# Copy to .env and fill in. `make up` reads this and seeds Djinn's settings.
# .env is gitignored — never commit your real key.

# openai | gemini
DJINN_PROVIDER=openai

# Your provider API key (sk-... for OpenAI). Required for wishes and for `make lamp`.
DJINN_API_KEY=

# Optional model overrides. Leave blank to use Djinn's defaults
# (openai: gpt-4o / text-embedding-3-small, gemini: gemini-2.0-flash / text-embedding-004).
DJINN_CHAT_MODEL=
DJINN_EMBEDDING_MODEL=
