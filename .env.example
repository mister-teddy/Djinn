# Copy to .env and fill in. `make up` reads this and seeds Djinn's settings.
# .env is gitignored — never commit your real key.

# openai | gemini
DJINN_PROVIDER=

# Your provider API key (sk-... for OpenAI). Required for wishes and for `make lamp`.
DJINN_API_KEY=

# Optional. The embedding model has a per-provider default (openai: text-embedding-3-small,
# gemini: gemini-embedding-001); a chat model must be chosen before wishing.
DJINN_CHAT_MODEL=
DJINN_EMBEDDING_MODEL=
