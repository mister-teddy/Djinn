# Copy to .env and fill in. `make up` reads this and seeds Djinn's settings.
# .env is gitignored — never commit your real key.

# Default: proxy (shown as "Djinn" in the UI). Other options: openai | gemini | anthropic | claude-max
DJINN_PROVIDER=

# Required only for bring-your-own-key providers.
DJINN_API_KEY=

# Required only for bring-your-own-key providers. The Djinn proxy chooses the model server-side.
DJINN_CHAT_MODEL=

# Optional manual-token fallback for local/dev proxy testing.
DJINN_SITE_TOKEN=
