{
  "name": "djinn-admin",
  "private": true,
  "description": "Djinn admin SPA (Lamp + Cave) — TypeScript/React/Tailwind built with @wordpress/scripts.",
  "scripts": {
    "build": "wp-scripts build",
    "start": "wp-scripts start",
    "typecheck": "tsc --noEmit",
    "lint:js": "wp-scripts lint-js app",
    "lint:css": "wp-scripts lint-style \"app/**/*.css\"",
    "format": "prettier --write \"app/**/*.{ts,tsx,css}\"",
    "codegen": "genql --schema schema/admin.graphql --output app/gql"
  },
  "devDependencies": {
    "@genql/cli": "^6.3.3",
    "@genql/runtime": "^2.10.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@wordpress/api-fetch": "^7.0.0",
    "@wordpress/element": "^6.0.0",
    "@wordpress/scripts": "^32.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0"
  }
}
