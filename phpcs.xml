<?xml version="1.0"?>
<ruleset name="Djinn">
	<description>WordPress coding style for the Djinn plugin; `phpcbf` auto-formats to it.</description>

	<!-- What to format: the shipped plugin code only (not vendor/build/dev scripts). -->
	<file>djinn.php</file>
	<file>src</file>
	<arg name="extensions" value="php"/>
	<arg name="basepath" value="."/>
	<arg value="ps"/>

	<!-- The WordPress coding style: tabs, spacing, array and brace formatting. -->
	<rule ref="WordPress-Core"/>

	<!-- Enforce the PHP 7.4 floor: any 8.0+ syntax or function fails the lint (WP core polyfills
	     like str_starts_with are recognized, so they pass). -->
	<config name="testVersion" value="7.4-"/>
	<rule ref="PHPCompatibilityWP">
		<!-- False positive: matches our Providers::family() method against the ancient `fam` extension. -->
		<exclude name="PHPCompatibility.Extensions.RemovedExtensions"/>
	</rule>
</ruleset>
