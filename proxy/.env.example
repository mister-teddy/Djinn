# Djinn proxy configuration. Copy to .env (gitignored) for local runs.

PORT=8080

# Supabase Postgres connection string (Project Settings → Database → Connection string → URI).
DATABASE_URL=postgres://user:pass@host:5432/postgres

# Upstream provider (OpenAI, or Google's OpenAI-compatible Gemini endpoint).
# Gemini:  https://generativelanguage.googleapis.com/v1beta/openai
UPSTREAM_BASE=https://api.openai.com/v1
UPSTREAM_KEY=

# We pick the models (ORG users don't), so we control cost.
ORG_CHAT_MODEL=gpt-4o-mini
ORG_EMBED_MODEL=text-embedding-3-small

# Free trial: three wishes, hard-capped by a dollar ceiling. MAX_OUTPUT_TOKENS caps any one call.
FREE_TRIAL_WISHES=3
FREE_TRIAL_USD=0.05
MAX_OUTPUT_TOKENS=2000

# Stripe (auto-recharge prepaid). Test keys are fine to start.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Protects /admin/provision (used by your sign-up flow to mint trial tokens).
ADMIN_TOKEN=
