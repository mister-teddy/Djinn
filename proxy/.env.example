# Djinn proxy configuration. Copy to .env (gitignored) for local runs.

PORT=8787

# Upstream provider (OpenAI, or Google's OpenAI-compatible Gemini endpoint).
# Gemini:  https://generativelanguage.googleapis.com/v1beta/openai
UPSTREAM_BASE=https://api.openai.com/v1
UPSTREAM_KEY=

# We pick the models (ORG users don't), so we control cost.
ORG_CHAT_MODEL=gpt-4o-mini
ORG_EMBED_MODEL=text-embedding-3-small

# Free trial: three wishes, hard-capped by a dollar ceiling so a runaway wish can't drain us.
FREE_TRIAL_WISHES=3
FREE_TRIAL_USD=0.05
# Caps output tokens on any single call (defence against one expensive request).
MAX_OUTPUT_TOKENS=2000

# Protects /admin/credit (scaffold — replace with Stripe webhooks).
ADMIN_TOKEN=

# Where the scaffold account store lives.
ACCOUNTS_FILE=./accounts.json
